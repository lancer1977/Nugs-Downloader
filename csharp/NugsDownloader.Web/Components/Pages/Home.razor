@page "/"
@using NugsDownloader.App.Abstractions
@using NugsDownloader.Domain.Entities
@using NugsDownloader.Domain.Providers
@using NugsDownloader.Domain.ValueObjects
@inject IProviderCatalog ProviderCatalog
@inject IJobRepository JobRepository
@inject IFileStateRepository FileStateRepository

<h1>NugsDownloader</h1>
<p>Dashboard for jobs, provider status, and file state.</p>

<div>
    <a href="/queue">Queue</a> |
    <a href="/login">Login</a> |
    <a href="/file-state">File State</a> |
    <a href="/provider-settings">Provider Settings</a>
</div>

<h2>Providers</h2>
@if (_providers.Count == 0)
{
    <p>No providers are configured.</p>
}
else
{
    <ul>
        @foreach (var provider in _providers)
        {
            <li>
                <strong>@provider.DisplayName</strong> (@provider.Id)
                - @DescribeCapabilities(provider.Capabilities)
            </li>
        }
    </ul>
}

<h2>Jobs</h2>
@if (_jobs.Count == 0)
{
    <p>No jobs have been queued yet.</p>
}
else
{
    <ul>
        @foreach (var job in _jobs.Take(5))
        {
            <li>
                <a href="@($"/jobs/{job.Id}")">@job.DisplayName</a>
                - @job.Status
                - @job.ProviderId
            </li>
        }
    </ul>
}

<h2>Recent Activity</h2>
@if (_recentActivity.Count == 0)
{
    <p>No recent activity has been recorded yet.</p>
}
else
{
    <ul>
        @foreach (var job in _recentActivity)
        {
            <li>@GetActivityTime(job): @job.DisplayName - @job.Status</li>
        }
    </ul>
}

<h2>File State Snapshot</h2>
@if (_fileStates.Count == 0)
{
    <p>No file state has been recorded yet.</p>
}
else
{
    <ul>
        @foreach (var state in _fileStates)
        {
            <li>@state.FilePath - @state.Status - @state.Kind</li>
        }
    </ul>
}

@code {
    private IReadOnlyList<IMediaProvider> _providers = Array.Empty<IMediaProvider>();
    private IReadOnlyList<DownloadJob> _jobs = Array.Empty<DownloadJob>();
    private IReadOnlyList<DownloadJob> _recentActivity = Array.Empty<DownloadJob>();
    private IReadOnlyList<FileState> _fileStates = Array.Empty<FileState>();

    protected override async Task OnInitializedAsync()
    {
        _providers = ProviderCatalog.GetProviders();
        _jobs = await JobRepository.ListAsync(CancellationToken.None);
        _recentActivity = _jobs
            .OrderByDescending(job => job.CompletedAt ?? job.StartedAt ?? job.RequestedAt)
            .Take(5)
            .ToArray();

        if (_jobs.Count > 0)
        {
            _fileStates = await FileStateRepository.GetByJobAsync(_jobs.Last().Id, CancellationToken.None);
        }
    }

    private static string DescribeCapabilities(ProviderCapabilities capabilities)
    {
        var bits = new List<string>();

        if (capabilities.SupportsAudio)
        {
            bits.Add("audio");
        }

        if (capabilities.SupportsVideo)
        {
            bits.Add("video");
        }

        if (capabilities.SupportsChapters)
        {
            bits.Add("chapters");
        }

        if (capabilities.SupportsResume)
        {
            bits.Add("resume");
        }

        if (capabilities.SupportsTokens)
        {
            bits.Add("tokens");
        }

        if (capabilities.SupportsPasswordLogin)
        {
            bits.Add("password login");
        }

        var summary = bits.Count > 0 ? string.Join(", ", bits) : "no feature hints";
        var formats = capabilities.SupportedFormats.Count > 0 ? string.Join(", ", capabilities.SupportedFormats) : "any format";
        var resolutions = capabilities.SupportedResolutions.Count > 0 ? string.Join(", ", capabilities.SupportedResolutions) : "any resolution";

        return $"{summary}. Formats: {formats}. Resolutions: {resolutions}.";
    }

    private static string GetActivityTime(DownloadJob job) =>
        (job.CompletedAt ?? job.StartedAt ?? job.RequestedAt).ToLocalTime().ToString("yyyy-MM-dd HH:mm");
}
